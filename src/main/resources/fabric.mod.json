{
  "schemaVersion": 1,
  "id": "autoreconnect",
  "version": "${version}",
  "name": "AutoReconnect",
  "description": "This mod will automatically try to reconnect you back to a server if you got disconnected.",
  "authors": [
    "Bstn1802",
    "Aeltumn"
  ],
  "contact": {
    "homepage": "https://github.com/Aeltumn/AutoReconnect",
    "sources": "https://github.com/Aeltumn/AutoReconnect",
    "issues": "https://github.com/Aeltumn/AutoReconnect/issues"
  },
  "license": "LGPL-3.0",
  "icon": "assets/icon16.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "autoreconnect.AutoReconnect"
    ],
    "modmenu": [
      "autoreconnect.config.ModMenuIntegration"
    ]
  },
  "mixins": [
    "autoreconnect.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.0",
    "minecraft": ">=26.1",
    "cloth-config": ">=${cloth_config_version}"
  }
}
